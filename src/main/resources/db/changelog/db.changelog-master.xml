<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        This is the entry point for all migrations.
        Add one <include> per changeset file, in order.
        NEVER remove or reorder existing includes — Liquibase
        uses this order + each file's checksum to track what has run.
    -->

    <include file="v1/001-create-users.xml"
             relativeToChangelogFile="true"/>

    <include file="v1/002-create-profiles.xml"
             relativeToChangelogFile="true"/>

<!--    <include file="v1/003-create-auth-tokens.xml"-->
<!--             relativeToChangelogFile="true"/>-->

</databaseChangeLog>